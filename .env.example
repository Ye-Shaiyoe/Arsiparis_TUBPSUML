APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=500000
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=contoh@gmail.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="contoh@gmail.com"
MAIL_FROM_NAME="Sistem Adminstrasi TUBPSUML"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

#Admin code
ADMIN_SECRET_CODE=

# reCAPTCHA v2 — untuk halaman register (checkbox widget)
# Daftar di: https://www.google.com/recaptcha/admin → pilih "v2 Checkbox"
RECAPTCHA_V2_SITE_KEY=
RECAPTCHA_V2_SECRET_KEY=

# reCAPTCHA v3 — untuk halaman login (invisible, auto-detect)
# Daftar di: https://www.google.com/recaptcha/admin → pilih "v3 Score based"
RECAPTCHA_V3_SITE_KEY=
RECAPTCHA_V3_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Untuk testing lokal, gunakan key test Google (selalu lolos):
# V2 test site key : 
# V2 test secret   :

ADMIN_SEED_NAME="Super Admin"
ADMIN_SEED_EMAIL=admin@domain.com
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NIP=
